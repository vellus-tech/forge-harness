{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/baseline-capability.schema.json",
  "title": "Forge baseline capability (.forge/product/current/capabilities/<capability>/spec.yaml)",
  "description": "Canonical baseline unit (doc §10.5). PRD/FRD/NFRD/TRD/DDD are aggregated or published views; the primary archive merge happens here, on capabilities with stable IDs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["capability_id", "version", "status", "requirements"],
  "properties": {
    "capability_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "enum": ["current", "deprecated", "retired"] },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "normative"],
        "properties": {
          "id": { "type": "string", "pattern": "^REQ-[A-Z0-9]+-[0-9]+$" },
          "title": { "type": "string", "minLength": 3 },
          "normative": { "enum": ["SHALL", "SHALL NOT", "SHOULD", "SHOULD NOT", "MAY"] },
          "scenarios": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "given", "when", "then"],
              "properties": {
                "id": { "type": "string", "pattern": "^SCN-[A-Z0-9]+-[0-9]+-[A-Z]$" },
                "given": { "type": "string", "minLength": 3 },
                "when": { "type": "string", "minLength": 3 },
                "then": { "type": "string", "minLength": 3 }
              }
            }
          },
          "contracts": { "type": "array", "items": { "type": "string" } },
          "tests": { "type": "array", "items": { "type": "string" } },
          "removed": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reason"],
            "properties": {
              "reason": { "type": "string" },
              "migration": { "type": "string" },
              "removed_by": { "type": "string" }
            }
          }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["change_id", "archived_at"],
        "properties": {
          "change_id": { "type": "string" },
          "archived_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
