{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/approvals.schema.json",
  "title": "Forge HITL approvals log (.forge/specs/active/<change-id>/approvals.yaml)",
  "description": "Human decisions at lifecycle gates (doc §12.1). Every decision except approve requires a reason; supersede also names the superseding change; iteration tracks the builder→validator loop (§14.6, escalates after 3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["approvals"],
  "properties": {
    "approvals": {
      "type": "array",
      "items": { "oneOf": [{ "$ref": "#/$defs/decisionEntry" }, { "$ref": "#/$defs/legacyEntry" }] }
    }
  },
  "$defs": {
    "legacyEntry": {
      "description": "Legacy §10.10 form (plain approval record). New entries should use the §12.1 decision form.",
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "approved_by", "approved_at"],
      "properties": {
        "gate": { "type": "string", "minLength": 3 },
        "approved_by": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}" },
        "commit": { "type": "string" },
        "scope": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "decisionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "decision", "decided_by", "decided_at"],
        "properties": {
          "gate": {
            "enum": ["requirements_reviewed", "design_reviewed", "tasks_reviewed", "implementation_verified", "human_archive_approval", "close"]
          },
          "decision": { "enum": ["approve", "review", "reject", "supersede", "abandon", "block"] },
          "reason": { "type": "string", "minLength": 3 },
          "decided_by": { "type": "string", "minLength": 1 },
          "decided_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}" },
          "iteration": { "type": "integer", "minimum": 1, "maximum": 3 },
          "commit": { "type": "string" },
          "scope": { "type": "string" },
          "notes": { "type": "string" },
          "superseded_by": { "type": "string" }
        },
        "allOf": [
          {
            "if": { "properties": { "decision": { "not": { "const": "approve" } } } },
            "then": { "required": ["reason"], "properties": { "reason": { "type": "string", "minLength": 3 } } }
          },
          {
            "if": { "properties": { "decision": { "const": "supersede" } } },
            "then": { "required": ["superseded_by"], "properties": { "superseded_by": { "type": "string", "minLength": 3 } } }
          }
        ]
      }
    }
  }
