{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/forge.schema.json",
  "title": "Forge core schemas: forge.yaml manifest and FORGE.md frontmatter",
  "$defs": {
    "nullableString": { "type": ["string", "null"] },
    "forgeFrontmatter": {
      "type": "object",
      "required": ["forge_version", "project", "sdd", "runtime", "integrations", "quality"],
      "additionalProperties": false,
      "properties": {
        "forge_version": { "const": 1 },
        "project": {
          "type": "object",
          "required": ["name", "display"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "display": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "repo_slug": { "type": ["string", "null"] },
            "default_branch": { "type": ["string", "null"] },
            "owners": { "type": "array", "items": { "type": "string" } },
            "domains": { "type": "array", "items": { "type": "string" } }
          }
        },
        "sdd": {
          "type": "object",
          "required": ["default_mode", "default_rigor", "default_scale", "archive_policy", "human_gate_required"],
          "additionalProperties": false,
          "properties": {
            "default_mode": { "enum": ["greenfield", "brownfield", "feature", "bugfix", "refactor"] },
            "default_rigor": { "enum": ["spec-first", "spec-anchored", "spec-as-source"] },
            "default_scale": { "type": "integer", "minimum": 0, "maximum": 4 },
            "archive_policy": { "enum": ["after_verified_implementation", "manual_override"] },
            "human_gate_required": { "type": "boolean" }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary_stack": { "$ref": "#/$defs/nullableString" },
            "package_manager": { "$ref": "#/$defs/nullableString" },
            "run": { "$ref": "#/$defs/nullableString" },
            "test": { "$ref": "#/$defs/nullableString" },
            "typecheck": { "$ref": "#/$defs/nullableString" },
            "lint": { "$ref": "#/$defs/nullableString" }
          }
        },
        "integrations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "jira": { "type": ["object", "string", "null"] },
            "github": { "type": ["object", "string", "null"] },
            "graph": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "path": { "type": "string" }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "required": ["evals_enabled"],
          "additionalProperties": false,
          "properties": {
            "evals_enabled": { "type": "boolean" },
            "runners_config": { "type": "string" }
          }
        }
      }
    },
    "forgeManifest": {
      "type": "object",
      "required": ["version", "harness", "specs"],
      "additionalProperties": false,
      "properties": {
        "version": { "const": 1 },
        "harness": {
          "type": "object",
          "required": ["name", "installed_at", "template_version", "adapters"],
          "additionalProperties": false,
          "properties": {
            "name": { "const": "forge" },
            "installed_at": { "type": "string" },
            "template_version": { "type": "string" },
            "adapters": {
              "type": "array",
              "items": {
                "enum": ["claude", "codex", "qwen", "kiro", "gemini", "cursor", "agents-skills", "forge-cli"]
              }
            }
          }
        },
        "specs": {
          "type": "object",
          "required": ["root", "active", "archived", "baseline"],
          "additionalProperties": false,
          "properties": {
            "root": { "type": "string" },
            "active": { "type": "string" },
            "archived": { "type": "string" },
            "baseline": { "type": "string" }
          }
        },
        "graph": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "root": { "type": "string" }
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "evals_root": { "type": "string" },
            "runners": { "type": "string" },
            "require_tests_before_archive": { "type": "boolean" },
            "require_traceability_before_archive": { "type": "boolean" },
            "require_human_approval_before_archive": { "type": "boolean" }
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "auto": { "type": "boolean" }
          }
        },
        "autonomy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "enum": ["hitl", "yolo"] },
            "gate_agent": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "model": { "type": "string" },
                "effort": { "enum": ["low", "medium", "high"] }
              }
            },
            "human_hard_stops": {
              "type": "array",
              "items": { "enum": ["requirements_reviewed", "design_reviewed", "tasks_reviewed", "implementation_verified", "human_archive_approval", "close"] }
            },
            "irreversible_hard_stops": {
              "type": "array",
              "items": { "enum": ["deploy_prd", "promote_staging", "adapter_removal", "branch_cleanup"] }
            }
          }
        }
      }
    }
  }
}
