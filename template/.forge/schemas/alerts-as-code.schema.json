{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/alerts-as-code.schema.json",
  "title": "Forge alerts-as-code (per-service golden-signal alerts)",
  "description": "Declarative alert definitions for a service's golden signals, versioned as code (REQ-04/REQ-10, design §2.4). Consumed by check-observability: a boundary declared without a matching alerts-as-code artifact is a finding naming the service.",
  "type": "object",
  "additionalProperties": false,
  "required": ["service", "alerts"],
  "properties": {
    "service": { "type": "string", "minLength": 1 },
    "alerts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expr", "severity", "for"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "expr": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "warning", "info"] },
          "for": { "type": "string", "pattern": "^[0-9]+[smhd]$" }
        }
      }
    }
  }
}
