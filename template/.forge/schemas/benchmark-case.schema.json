{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge/schemas/benchmark-case.schema.json",
  "title": "benchmark-case/v1 — canonical Forge eval benchmark case",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "category", "prompt", "artifacts", "grading", "budget"],
  "properties": {
    "schema": { "const": "benchmark-case/v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "category": { "type": "string", "enum": ["greenfield", "brownfield", "refactor", "docs", "multi-module"] },
    "prompt": { "type": "string", "minLength": 8 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    },
    "grading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectations", "baseline_pass_rate", "variant_pass_rate"],
      "properties": {
        "expectations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "baseline_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "variant_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "runs"],
      "properties": {
        "profile": { "type": "string", "enum": ["quick", "standard", "regulated", "brownfield-heavy"] },
        "runs": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
