#!/usr/bin/env bash
# Forge pre-push (§20.4) — runs the project's own typecheck + tests (as declared in the
# FORGE.md frontmatter `runtime:` block) before pushing a work branch. Empty commands are
# skipped (greenfield). Raw output goes to /tmp (context-overflow discipline §17.6).
set -u

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# Consume stdin (git feeds "<local ref> <local sha> <remote ref> <remote sha>" lines)
# before anything else touches it, and run the docs-reviewed gate. This check is
# independent of .forge/FORGE.md — it applies to any repo using this hook.
INPUT="$(cat)"
DOCS_LIB="$ROOT/.forge/hooks/git/lib/check-docs-reviewed.sh"
if [ -f "$DOCS_LIB" ]; then
  # shellcheck disable=SC1090
  . "$DOCS_LIB"
  if ! printf '%s\n' "$INPUT" | REPO="$ROOT" check_docs_reviewed; then
    exit 1
  fi
fi

FORGE_MD="$ROOT/.forge/FORGE.md"
[ -f "$FORGE_MD" ] || { echo "pre-push OK (sem harness)"; exit 0; }

fm_field() {  # fm_field <key> — value of "  <key>:" inside the runtime: block
  awk -v key="$1" '
    /^runtime:/ { inblk=1; next }
    inblk && /^[a-z_]+:/ { exit }
    inblk && $0 ~ "^  "key":" { sub("^  "key":[[:space:]]*", ""); print; exit }
  ' "$FORGE_MD"
}

gate_deps_ready() {  # gate_deps_ready <cmd> — false quando o gate depende de deps Node ainda não instaladas
  # Um gate JS (pnpm/npm/npx/yarn) num clone recém-feito falha porque `node_modules` não existe —
  # isso não é um erro de código, é infra ausente (§20.4). Degradar com elegância: avisar + pular,
  # deixando o typecheck pesado para /forge:verify. Toolchains não-JS seguem inalterados.
  case "$1" in
    *pnpm*|*npm*|*npx*|*yarn*)
      [ -d "$ROOT/node_modules" ] && return 0
      return 1 ;;
  esac
  return 0
}

run_check() {  # run_check <label> <cmd>
  local label="$1" cmd="$2" log
  [ -n "$cmd" ] || { echo "pre-push: $label não definido — skip"; return 0; }
  if ! gate_deps_ready "$cmd"; then
    echo "pre-push: $label PULADO — node_modules/ ausente (rode 'pnpm install' ou deixe para /forge:verify)"
    return 0
  fi
  # NB: o template do mktemp precisa TERMINAR nos X (BSD/macOS falha com sufixo após o X, ex.:
  # `-XXXXXX.log`). Sem sufixo de extensão — é um arquivo de log temporário efêmero.
  log="$(mktemp "${TMPDIR:-/tmp}/forge-prepush-XXXXXX")"
  if (cd "$ROOT" && eval "$cmd") >"$log" 2>&1; then
    echo "pre-push: $label OK"
  else
    echo "pre-push BLOQUEADO: $label falhou — tail:"
    tail -20 "$log"
    exit 1
  fi
}

run_check "typecheck" "$(fm_field typecheck)"
run_check "test" "$(fm_field test)"
echo "pre-push OK"
